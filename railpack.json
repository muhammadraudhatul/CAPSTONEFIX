{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "build": {
      "commands": [
        "...",
        "python -m venv /app/.venv",
        "/app/.venv/bin/python -m pip install --upgrade pip",
        "/app/.venv/bin/pip install -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "paths": [
      "/app/.venv/bin"
    ]
  }
}