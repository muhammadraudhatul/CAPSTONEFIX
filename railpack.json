{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install:python": {
      "inputs": [
        {
          "local": true,
          "include": [
            "requirements.txt"
          ]
        }
      ],
      "commands": [
        "python -m venv /app/.venv",
        "/app/.venv/bin/pip install --upgrade pip",
        "/app/.venv/bin/pip install -r requirements.txt"
      ],
      "deployOutputs": [
        {
          "include": [
            "/app/.venv"
          ]
        }
      ]
    }
  },
  "deploy": {
    "inputs": [
      "...",
      {
        "step": "install:python",
        "include": [
          "/app/.venv"
        ]
      }
    ],
    "paths": [
      "/app/.venv/bin"
    ]
  }
}